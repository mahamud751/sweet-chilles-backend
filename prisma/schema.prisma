generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SAVASAACHI_ADMIN
  RESTAURANT_OWNER
  RESTAURANT_STAFF
}

enum LoyaltyStage {
  REGISTERED
  WELCOME_REDEEMED
  RETURN_REDEEMED
  THIRD_REDEEMED
  LOYALTY_ACTIVE
  GOLD
}

enum VoucherType {
  WELCOME
  RETURN
  THIRD
  LOYALTY
  GOLD
}

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

enum CompetitionStatus {
  DRAFT
  ACTIVE
  CLOSED
  WINNER_ANNOUNCED
}

enum CampaignType {
  BIRTHDAY
  INACTIVE
  QUIET_DAY
  SEASONAL
  SYSTEM_UNLOCK
}

/// White-label restaurant tenant (Grand Milon, Sweet Chillies, etc.)
model Restaurant {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  appDisplayName        String
  tagline               String?
  primaryColor          String   @default("#F15A24")
  logoUrl               String?
  welcomeDiscountPercent Int     @default(30)
  foodOnlyExcludesDrinks Boolean @default(true)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users         User[]
  members       Member[]
  competitions  Competition[]
  vouchers      Voucher[]
  visits        Visit[]
  campaigns     CampaignTemplate[]
  bookings      Booking[]
  orders        Order[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  displayName  String
  avatarUrl    String?
  restaurantId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  visits     Visit[]     @relation("StaffVisits")
}

/// End customer / loyalty member
model Member {
  id             String       @id @default(cuid())
  restaurantId   String
  email          String
  passwordHash   String
  name           String
  phone          String?
  avatarUrl      String?
  birthday       DateTime?
  loyaltyStage   LoyaltyStage @default(REGISTERED)
  isGoldMember   Boolean      @default(false)
  loyaltyVisitsRemaining Int  @default(0)
  referralCode   String       @unique @default(cuid())
  lastVisitAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  restaurant         Restaurant          @relation(fields: [restaurantId], references: [id])
  vouchers           Voucher[]
  visits             Visit[]
  competitionEntries CompetitionEntry[]
  notifications      MemberNotification[]
  orders             Order[]
  bookings           Booking[]

  @@unique([restaurantId, email])
}

model Competition {
  id              String            @id @default(cuid())
  restaurantId    String
  title           String
  prizeDescription String
  status          CompetitionStatus @default(DRAFT)
  platforms       String[]
  entryMechanics  String            @default("Follow, Like, Share, Comment DONE")
  targetEntries   Int               @default(500)
  startsAt        DateTime?
  endsAt          DateTime?
  winnerMemberId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id])
  entries    CompetitionEntry[]
}

model CompetitionEntry {
  id             String   @id @default(cuid())
  competitionId  String
  memberId       String?
  externalHandle String?
  messengerSent  Boolean  @default(false)
  voucherGranted Boolean  @default(false)
  createdAt      DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id])
  member      Member?     @relation(fields: [memberId], references: [id])
}

model Voucher {
  id           String        @id @default(cuid())
  restaurantId String
  memberId     String
  type         VoucherType
  percentOff   Int
  qrToken      String        @unique @default(cuid())
  status       VoucherStatus @default(ACTIVE)
  validFrom    DateTime      @default(now())
  validUntil   DateTime
  redeemedAt   DateTime?
  visitId      String?       @unique
  createdAt    DateTime      @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  member     Member     @relation(fields: [memberId], references: [id])
  visit      Visit?     @relation(fields: [visitId], references: [id])
}

model Visit {
  id           String   @id @default(cuid())
  restaurantId String
  memberId     String
  staffUserId  String?
  billAmount   Decimal? @db.Decimal(10, 2)
  discountAmount Decimal? @db.Decimal(10, 2)
  redeemedAt   DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  member     Member     @relation(fields: [memberId], references: [id])
  staff      User?      @relation("StaffVisits", fields: [staffUserId], references: [id])
  voucher    Voucher?
}

model CampaignTemplate {
  id           String       @id @default(cuid())
  restaurantId String
  type         CampaignType
  title        String
  bodyTemplate String
  isEnabled    Boolean      @default(true)
  createdAt    DateTime     @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, type])
}

model MemberNotification {
  id        String   @id @default(cuid())
  memberId  String
  title     String
  body      String
  read      Boolean  @default(false)
  sentAt    DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])
}

model Booking {
  id           String   @id @default(cuid())
  restaurantId String
  memberId     String
  partySize    Int
  bookedFor    DateTime
  status       String   @default("CONFIRMED")
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  member     Member     @relation(fields: [memberId], references: [id])
}

model Order {
  id           String   @id @default(cuid())
  restaurantId String
  memberId     String
  totalAmount  Decimal  @db.Decimal(10, 2)
  channel      String   @default("TAKEAWAY")
  status       String   @default("PLACED")
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  member     Member     @relation(fields: [memberId], references: [id])
}
